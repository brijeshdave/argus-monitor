{
  "name": "@argus/db",
  "version": "1.0.0",
  "private": true,
  "description": "Argus data layer — Drizzle schemas, clients, migrations and seed for the master + telemetry databases.",
  "author": "Brijesh Dave <https://github.com/brijeshdave>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "pnpm run build && drizzle-kit generate --config=drizzle.master.config.ts && drizzle-kit generate --config=drizzle.telemetry.config.ts",
    "migrate": "node dist/migrate.js",
    "seed": "node dist/seed.js"
  },
  "dependencies": {
    "@argus/core": "workspace:*",
    "@argus/shared": "workspace:*",
    "@electric-sql/pglite": "^0.2.15",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
