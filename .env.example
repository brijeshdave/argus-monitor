# ─────────────────────────────────────────────────────────────────────────────
# Argus — Monitoring Platform · Author: Brijesh Dave <https://github.com/brijeshdave>
# Copy to `.env` and adjust. NEVER commit a real .env (it is git-ignored).
# Every value here has a safe default in code; this file documents the surface.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info                       # trace|debug|info|warn|error
TZ=UTC

# ── Network / bind ───────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
FRONTEND_PORT=8081
PUBLIC_URL=http://localhost:8081     # external URL operators use (for OIDC redirects)

# White-label branding — applied at BUILD time only (no in-app setting exists).
# Leave blank for the defaults ("Argus" / "Monitoring").
VITE_BRAND_NAME=
VITE_BRAND_TAGLINE=

# Reverse proxy: OFF by default. Set to a CIDR/hop-count/`true` ONLY when Argus
# sits behind a proxy you control, so X-Forwarded-For is trusted. XFF is spoofable.
# Set TRUST_PROXY=true when running behind the bundled Caddy TLS proxy (below).
TRUST_PROXY=

# ── HTTPS via Caddy (OPTIONAL, opt-in) ───────────────────────────────────────
# Terminates TLS for the whole stack using Let's Encrypt with the Cloudflare
# DNS-01 challenge (no inbound :80 needed for issuance). To enable:
#   1) COMPOSE_PROFILES=tls           # turns the caddy service on
#   2) set ARGUS_DOMAIN / ACME_EMAIL / CF_API_TOKEN below
#   3) TRUST_PROXY=true and PUBLIC_URL=https://your-domain
#   4) ./argus up   (then point agents at https://your-domain)
# COMPOSE_PROFILES=tls
ARGUS_DOMAIN=                         # e.g. argus.example.com (the public hostname)
ACME_EMAIL=                          # contact e-mail for Let's Encrypt
# Cloudflare API token with Zone:DNS:Edit on the domain's zone (DNS-01 challenge).
CF_API_TOKEN=

# ── Database (master + telemetry are SEPARATE logical databases) ──────────────
# Single SQL dialect: PostgreSQL.
#   driver "pg"     → a real PostgreSQL server (production / Docker).
#   driver "pglite" → embedded Postgres (WASM), zero-setup dev + tests (same dialect).
DB_DRIVER=pg
# Master DB: identity, RBAC, configs, encrypted secrets.
MASTER_DATABASE_URL=postgres://argus:argus@postgres:5432/argus_master
# Telemetry DB: metrics, events, logs, audit (high-volume, swappable to Timescale).
TELEMETRY_DATABASE_URL=postgres://argus:argus@postgres:5432/argus_telemetry
# Development databases (same Postgres, "_dev" suffix). Created by `./argus dev-db init`;
# `./argus dev-db copy` clones prod → dev. A dev backend points MASTER_/TELEMETRY_
# DATABASE_URL at these. The CLI derives them from the URLs above, so these are optional.
# DEV_MASTER_DATABASE_URL=postgres://argus:argus@postgres:5432/argus_master_dev
# DEV_TELEMETRY_DATABASE_URL=postgres://argus:argus@postgres:5432/argus_telemetry_dev
# PGlite data directory (used only when DB_DRIVER=pglite):
PGLITE_DIR=./data/pglite

# ── Redis + queue (OPTIONAL) ─────────────────────────────────────────────────
# Enable to coordinate remote workers, cross-instance WS fan-out, rate-limit.
# Disabled => in-process queue + in-memory pub/sub (single-node only).
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
# Where queue jobs run: "inline" (in backend) or "worker" (separate process/host).
WORKER_MODE=worker

# ── Security / crypto ────────────────────────────────────────────────────────
# 32-byte base64 master key for AES-256-GCM at-rest encryption of all secrets.
# Generate: `./argus gen-key`. Rotating this re-wraps secrets (see docs/security).
ENCRYPTION_KEY=
JWT_SECRET=                          # HS256 signing secret for access tokens
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Static superadmin API token for CLI/automation (treated as superadmin).
ADMIN_TOKEN=
# OPTIONAL — first-seed only. Sets the bootstrap owner (immutable superadmin)
# password on the VERY FIRST `./argus seed`. If left blank, a strong password is
# generated and printed once. Ignored once the owner exists (change it later in the
# UI or via `./argus reset-password`). Safe to remove after initial setup.
ADMIN_PASSWORD=
RATE_LIMIT_MAX=600                   # requests/min per token, IP fallback

# ── Agent link ───────────────────────────────────────────────────────────────
# Agents authenticate with a per-agent connection key minted in the UI.
# Optional mTLS for the agent control channel (paths inside the container/host).
AGENT_MTLS_ENABLED=false
AGENT_TLS_CA=
AGENT_TLS_CERT=
AGENT_TLS_KEY=

# ── OIDC (OPTIONAL, generic) ─────────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=${PUBLIC_URL}/auth/oidc/callback

# ── Telemetry (OpenTelemetry, OPTIONAL export) ───────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=argus-backend

# ── Data directory (bind-mounted in Docker; holds DB/spool/backups/agent builds)
DATA_DIR=./data

# ── FortiGate DHCP lease lookup (OPTIONAL) ───────────────────────────────────
# When DHCP runs on a FortiGate, Argus pulls leases (hostname + MAC for every
# subnet) from the FortiOS REST API to name connected clients the agent can't
# resolve. Create a REST API admin + token on the FortiGate. Leave URL/TOKEN blank
# to disable.
FORTIGATE_URL=
FORTIGATE_TOKEN=
# Skip TLS verification for the FortiGate's self-signed cert (set false to enforce).
FORTIGATE_INSECURE=true
# FORTIGATE_INTERVAL_MS=300000
